{
  "name": "my-app",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "my-app": "./src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "start": "bun src/cli.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "bun run --parallel 'build:*'",
    "build:bun": "bun build src/cli.ts --outdir dist --target bun --minify",
    "build:darwin-arm64": "bun build src/cli.ts --compile --minify --target bun-darwin-arm64 --outfile dist/my-app-darwin-arm64",
    "build:darwin-x64": "bun build src/cli.ts --compile --minify --target bun-darwin-x64 --outfile dist/my-app-darwin-x64",
    "build:linux-x64": "bun build src/cli.ts --compile --minify --target bun-linux-x64 --outfile dist/my-app-linux-x64",
    "build:linux-arm64": "bun build src/cli.ts --compile --minify --target bun-linux-arm64 --outfile dist/my-app-linux-arm64",
    "build:windows-x64": "bun build src/cli.ts --compile --minify --target bun-windows-x64 --outfile dist/my-app-windows-x64.exe",
    "changeset": "changeset"
  },
  "dependencies": {
    "gunshi": "0.29.2"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.5.2",
    "@changesets/cli": "2.30.0",
    "@gunshi/docs": "0.29.2",
    "@tsconfig/bun": "1.0.10",
    "@types/bun": "1.3.9",
    "@typescript/native-preview": "7.0.0-dev.20260227.1",
    "oxfmt": "0.35.0",
    "oxlint": "1.50.0",
    "vitest": "4.0.18"
  }
}
